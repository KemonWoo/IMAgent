<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F23">

    <!-- Status Bar — 精简 V=6 D=3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#0F0F23">

        <View
            android:id="@+id/status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/status_dot_offline" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="断开"
            android:textColor="#CBD5E1"
            android:textSize="13sp"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/settings_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙"
            android:textColor="#64748B"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="#1E1E3A" />

    <!-- Voice Mode -->
    <LinearLayout
        android:id="@+id/voice_mode_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/subtitle_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点按开始对话"
            android:textColor="#CBD5E1"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/subtitle_ai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#7C5CFC"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/mic_btn"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="🎤"
            android:textSize="48sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/mic_circle"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点按说话"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/text_mode_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌨ 切换到文字"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginTop="64dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Text Mode -->
    <LinearLayout
        android:id="@+id/text_mode_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/chat_messages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />
        </ScrollView>

        <!-- Input Bar — 按钮权重分层 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bar_bg">

            <!-- 辅助：文件 -->
            <ImageButton
                android:id="@+id/file_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:srcCompat="@drawable/ic_attach"
                android:background="@drawable/circle_secondary"
                android:scaleType="centerInside"
                android:tint="#94A3B8"
                android:contentDescription="文件"
                android:layout_marginEnd="4dp" />

            <!-- 辅助：图片 -->
            <ImageButton
                android:id="@+id/image_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:srcCompat="@drawable/ic_image"
                android:background="@drawable/circle_secondary"
                android:scaleType="centerInside"
                android:tint="#94A3B8"
                android:contentDescription="图片"
                android:layout_marginEnd="4dp" />

            <!-- 辅助：语音 -->
            <ImageButton
                android:id="@+id/voice_mode_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:srcCompat="@drawable/ic_mic"
                android:background="@drawable/circle_secondary"
                android:scaleType="centerInside"
                android:tint="#94A3B8"
                android:contentDescription="语音"
                android:layout_marginEnd="4dp" />

            <!-- 输入框 -->
            <EditText
                android:id="@+id/input_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="输入消息…"
                android:textColorHint="#475569"
                android:textColor="#CBD5E1"
                android:textSize="14sp"
                android:background="@null"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <!-- 主操作：发送 — 填充色 + 略大 -->
            <ImageButton
                android:id="@+id/send_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:srcCompat="@drawable/ic_send"
                android:background="@drawable/circle_send"
                android:scaleType="centerInside"
                android:contentDescription="发送"
                android:enabled="true"
                android:alpha="1.0" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
