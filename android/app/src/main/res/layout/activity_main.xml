<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F23">

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#1A1A2E">

        <View
            android:id="@+id/status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/status_dot_offline" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="断开"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/settings_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textColor="#888888"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Voice Mode -->
    <LinearLayout
        android:id="@+id/voice_mode_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/subtitle_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="按住说话开始对话"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/subtitle_ai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#8B5CF6"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/mic_btn"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="🎤"
            android:textSize="48sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/mic_circle"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="按住说话"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/text_mode_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌨️ 切换到文字"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginTop="64dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Text Mode -->
    <LinearLayout
        android:id="@+id/text_mode_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/chat_messages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </ScrollView>

        <!-- Input Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/input_bar_bg">

            <EditText
                android:id="@+id/input_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="输入消息…"
                android:textColorHint="#666666"
                android:textColor="#E0E0E0"
                android:textSize="15sp"
                android:background="@null"
                android:maxLines="4"
                android:inputType="textMultiLine" />

            <Button
                android:id="@+id/file_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_accent"
                android:drawableStart="@drawable/ic_attach"
                android:text=""
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/image_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_image"
                android:background="@drawable/circle_accent"
                android:scaleType="centerInside"
                android:contentDescription="发送图片"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/voice_mode_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_accent"
                android:drawableStart="@drawable/ic_mic"
                android:text=""
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/send_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_accent"
                android:drawableStart="@drawable/ic_send"
                android:text=""
                android:enabled="false"
                android:alpha="0.4" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
